# ==============================================
# Model Endpoint (OpenAI-compatible)
# ==============================================
OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_API_KEY=
MODEL_NAME=your-230b-model-name
REQUEST_TIMEOUT_SEC=900

# ==============================================
# Task Selection
# - RUN_ALL=true: run all experiment yaml files
# - EXPERIMENT_TASKS: comma-separated slug/id list (or use "all")
# - EXPERIMENT_TASK_FILE: optional text file; one slug/id per line
# ==============================================
RUN_ALL=true
EXPERIMENT_TASKS=all
EXPERIMENT_TASK_FILE=

# ==============================================
# Reliability / Failure Strategy
# ==============================================
CONTINUE_ON_ERROR=true
MAX_WORKERS=1
MAX_API_RETRIES=2
RETRY_BACKOFF_SEC=2
RUN_DRY_RUN=false

# ==============================================
# Pipeline Toggles
# ==============================================
PIPELINE_SKIP_RUN=false
PIPELINE_SKIP_AGGREGATE=false
PIPELINE_SKIP_SITE=false

# ==============================================
# Paths (relative or absolute)
# ==============================================
CONFIG_DIR=experiments
RAW_DIR=results/raw
METRICS_DIR=results/metrics
SUMMARY_JSON_PATH=results/metrics/summary.json
SUMMARY_CSV_PATH=results/summary.csv
TEMPLATE_DIR=web/template
SITE_DIR=site

# ==============================================
# Local Preview
# ==============================================
SITE_PORT=4173

# ==============================================
# Optional Playwright browser knobs
# ==============================================
ENABLE_HEADLESS_BROWSER=false
BROWSER_BASE_URL=
BROWSER_TIMEOUT_SEC=60
BROWSER_MAX_CHARS=3000
BROWSER_MAX_LINKS=8
BROWSER_WAIT_UNTIL=domcontentloaded
BROWSER_HEADLESS=true
BROWSER_DISABLE_SANDBOX=true
BROWSER_REFRESH_EVERY_ROUND=true
BROWSER_ROUND_INTERVAL=1
BROWSER_REQUIRED=false
